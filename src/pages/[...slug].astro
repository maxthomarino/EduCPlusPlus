---
import { getCollection } from "astro:content";
import DocLayout from "../layouts/DocLayout.astro";
import { buildSidebarData } from "../lib/sidebar-data.js";
import { buildToc } from "../lib/toc.js";
import type { ParsedFile, Section, SidebarFile } from "../lib/types.js";

import PageHeader from "../components/content/PageHeader.astro";
import FaqSection from "../components/content/FaqSection.astro";
import HowItWorks from "../components/content/HowItWorks.astro";
import KeyTakeaways from "../components/content/KeyTakeaways.astro";
import WatchOut from "../components/content/WatchOut.astro";
import NumberedSection from "../components/content/NumberedSection.astro";
import DecisionGuide from "../components/content/DecisionGuide.astro";
import GenericSection from "../components/content/GenericSection.astro";
import CodeBlock from "../components/content/CodeBlock.astro";
import type { GenericNamedSection } from "../lib/types.js";

export async function getStaticPaths() {
  const allLessons = await getCollection("lessons");
  const sidebarData = buildSidebarData(allLessons.map((e) => e.data as unknown as ParsedFile));

  // Build a flat ordered list for prev/next navigation
  const orderedSlugs: string[] = [];
  for (const mod of sidebarData) {
    for (const sub of mod.subfolders) {
      for (const file of sub.files) {
        orderedSlugs.push(file.slug);
      }
    }
  }

  return allLessons.map((entry) => {
    const idx = orderedSlugs.indexOf(entry.data.slug);
    const prevSlug = idx > 0 ? orderedSlugs[idx - 1] : null;
    const nextSlug = idx < orderedSlugs.length - 1 ? orderedSlugs[idx + 1] : null;

    // Find titles for prev/next
    const findTitle = (slug: string | null) => {
      if (!slug) return null;
      const lesson = allLessons.find((l) => l.data.slug === slug);
      return lesson ? lesson.data.header.shortTitle : null;
    };

    return {
      params: { slug: entry.data.slug },
      props: {
        entry: entry.data,
        sidebarData,
        prev: prevSlug ? { slug: prevSlug, title: findTitle(prevSlug) } : null,
        next: nextSlug ? { slug: nextSlug, title: findTitle(nextSlug) } : null,
      },
    };
  });
}

const { entry, sidebarData, prev, next } = Astro.props;
const toc = buildToc(entry.sections);
const language = entry.fileName === "CMakeLists.txt" ? "cmake" : "cpp";
const isGeneralDiscussion = (section: Section) =>
  section.type === "generic-section" && /^general discussion$/i.test(section.title.trim());
const mainSections = entry.sections.filter((section: Section) => !isGeneralDiscussion(section));
const generalDiscussionSections = entry.sections.filter(
  (section: Section): section is GenericNamedSection => isGeneralDiscussion(section)
);
---

<DocLayout
  title={entry.header.shortTitle}
  description={entry.header.description}
  sidebarData={sidebarData}
  currentSlug={entry.slug}
  toc={toc}
>
  <PageHeader
    header={entry.header}
    moduleName={entry.moduleName}
    moduleTitle={entry.moduleTitle}
    subfolder={entry.subfolder}
  />

  {mainSections.map((section: Section) => {
    switch (section.type) {
      case "faq":
        return <FaqSection questions={section.questions} />;
      case "how-it-works":
        return <HowItWorks title={section.title} content={section.content} />;
      case "key-takeaways":
        return <KeyTakeaways items={section.items} />;
      case "numbered-section":
        return <NumberedSection section={section} />;
      case "decision-guide":
        return <DecisionGuide title={section.title} content={section.content} />;
      case "generic-section":
        return <GenericSection title={section.title} content={section.content} />;
      case "code":
        return <CodeBlock code={section.code} language={section.language || language} />;
      case "watch-out":
        return <WatchOut content={section.content} />;
      default:
        return null;
    }
  })}

  <!-- Prev / Next navigation -->
  {(prev || next) && (
    <nav class="pn">
      {prev ? (
        <a href={`/${prev.slug}`} class="pn-link pn-prev">
          <span class="pn-dir">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Previous
          </span>
          <span class="pn-title">{prev.title}</span>
        </a>
      ) : (
        <div />
      )}
      {next ? (
        <a href={`/${next.slug}`} class="pn-link pn-next">
          <span class="pn-dir">
            Next
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </span>
          <span class="pn-title">{next.title}</span>
        </a>
      ) : (
        <div />
      )}
    </nav>
  )}

  {generalDiscussionSections.map((section) => (
    <GenericSection title={section.title} content={section.content} />
  ))}
</DocLayout>

<style>
  /* Prev / Next navigation */
  .pn {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.65rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-soft);
    animation: pn-in 400ms cubic-bezier(0.22, 0.8, 0.22, 1) 120ms both;
  }

  .pn-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.85rem 1rem;
    border-radius: 0.65rem;
    border: 1px solid var(--border-soft);
    background: var(--surface-elevated);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .pn-link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--border-strong);
  }

  .pn-next {
    text-align: right;
    align-items: flex-end;
  }

  .pn-dir {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.7rem;
    font-weight: 650;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .pn-next .pn-dir {
    justify-content: flex-end;
  }

  .pn-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 640;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  @keyframes pn-in {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pn { animation: none; }
  }
</style>
