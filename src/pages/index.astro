---
import { getCollection } from "astro:content";
import DocLayout from "../layouts/DocLayout.astro";
import { buildSidebarData } from "../lib/sidebar-data.js";
import type { ParsedFile } from "../lib/types.js";
import HeroSection from "../components/landing/HeroSection.astro";
import FeatureCards from "../components/landing/FeatureCards.astro";
import LearningPath from "../components/landing/LearningPath.astro";
import StatsBar from "../components/landing/StatsBar.astro";
import CTACard from "../components/landing/CTACard.astro";
import Footer from "../components/landing/Footer.astro";

const allLessons = await getCollection("lessons");
const allArticles = await getCollection(
  "articles",
  ({ data }) => import.meta.env.DEV || !data.draft
);
const sidebarData = buildSidebarData(allLessons.map((e) => e.data as unknown as ParsedFile));

// Total counts
const totalFiles = allLessons.length;
const totalModules = sidebarData.length;
const totalArticles = allArticles.length;
const latestArticles = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const firstLessonSlug = sidebarData[0]?.subfolders[0]?.files[0]?.slug || "";

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function getLevel(order: number): { label: string; tone: string } {
  if (order <= 4) {
    return { label: "Beginner", tone: "border: 1px solid color-mix(in srgb, var(--success) 24%, var(--border-soft)); background: color-mix(in srgb, var(--success-soft) 55%, var(--surface-elevated)); color: var(--success);" };
  }
  if (order <= 9) {
    return { label: "Intermediate", tone: "border: 1px solid color-mix(in srgb, var(--warning) 24%, var(--border-soft)); background: color-mix(in srgb, var(--warning-soft) 55%, var(--surface-elevated)); color: var(--warning);" };
  }
  return { label: "Advanced", tone: "border: 1px solid color-mix(in srgb, var(--deep) 24%, var(--border-soft)); background: color-mix(in srgb, var(--deep-soft) 55%, var(--surface-elevated)); color: var(--deep);" };
}
---

<DocLayout
  title="EduC++ Documentation"
  description="Master modern C++20 through structured lessons, runnable examples, and interactive quizzes — a professional learning platform for C++ developers."
  sidebarData={sidebarData}
  currentSlug=""
>
  <div class="stagger-reveal" style="--stagger-delay: 0ms">
    <HeroSection
      totalLessons={totalFiles}
      totalModules={totalModules}
      totalArticles={totalArticles}
      firstLessonSlug={firstLessonSlug}
    />
  </div>

  <div class="stagger-reveal" style="--stagger-delay: 60ms">
    <FeatureCards />
  </div>

  <div class="stagger-reveal mb-3" style="--stagger-delay: 120ms">
    <h2 class="display-font text-2xl font-semibold tracking-tight" style="color: var(--text-primary);">Explore <span class="gradient-title">Modules</span></h2>
  </div>

  <div class="stagger-reveal grid gap-4 sm:grid-cols-2" style="--stagger-delay: 180ms">
    {sidebarData.map((mod) => {
      const firstFile = mod.subfolders[0]?.files[0];
      const fileCount = mod.subfolders.reduce((sum, sub) => sum + sub.files.length, 0);
      const level = getLevel(mod.order);
      return (
        <a href={firstFile ? `/${firstFile.slug}` : "#"} class="surface-card hover-lift group page-reveal block p-5">
          <div class="mb-3 flex items-center justify-between gap-3">
            <span
              class="inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-semibold tracking-[0.04em]"
              style={level.tone}
            >
              {level.label}
            </span>
            <span class="text-[11px] font-medium tracking-[0.06em]" style="color: var(--text-muted);">
              Module {String(mod.order).padStart(2, "0")}
            </span>
          </div>
          <div class="flex items-start gap-3">
            <span
              class="display-font flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-sm font-semibold"
              style="background: var(--accent-soft); color: var(--accent);"
            >
              {mod.order}
            </span>
            <div class="min-w-0">
              <h3 class="display-font text-lg font-semibold leading-snug tracking-tight" style="color: var(--text-primary);">
                {mod.title}
              </h3>
              <p class="mt-1 text-sm" style="color: var(--text-muted);">
                {fileCount} {fileCount === 1 ? "lesson" : "lessons"} - {" "}
                {mod.subfolders.map((s) => s.name.replace(/_/g, " ")).join(", ")}
              </p>
            </div>
          </div>
        </a>
      );
    })}
  </div>

  <div class="stagger-reveal" style="--stagger-delay: 240ms">
    <LearningPath sidebarData={sidebarData} />
  </div>

  <div class="stagger-reveal" style="--stagger-delay: 300ms">
    <StatsBar
      totalLessons={totalFiles}
      totalModules={totalModules}
      totalQuizQuestions={128}
      totalTopics={15}
    />
  </div>

  <div class="stagger-reveal" style="--stagger-delay: 360ms">
    <CTACard
      eyebrow="Also Available"
      title="C++ Articles"
      description="Deep dives and practical discussions beyond the lesson path."
      linkText="Browse all articles"
      linkHref="/articles"
    />
  </div>

  <div class="stagger-reveal" style="--stagger-delay: 420ms">
    <CTACard
      eyebrow="Test Your Knowledge"
      title="C++ Quiz"
      description="128 multiple choice questions covering all 15 topics, from CS fundamentals to advanced C++20."
      linkText="Start quiz"
      linkHref="/quiz"
      variant="deep"
    />
  </div>

  <section class="stagger-reveal page-reveal mt-10" style="--stagger-delay: 480ms">
    <div class="mb-3 flex items-end justify-between gap-3">
      <h2 class="display-font text-2xl font-semibold tracking-tight" style="color: var(--text-primary);">
        <span class="gradient-title">C++ Articles</span>
      </h2>
      <a href="/articles" class="text-sm font-medium" style="color: var(--accent);">View all</a>
    </div>

    {latestArticles.length > 0 ? (
      <div class="grid gap-4">
        {latestArticles.map((article) => (
          <a href={`/articles/${article.slug}`} class="surface-card hover-lift block p-5">
            <p class="text-xs font-medium tracking-[0.06em]" style="color: var(--text-muted);">
              {formatDate(article.data.publishDate)} · {article.data.author}
            </p>
            <h3 class="display-font mt-1 text-xl font-semibold tracking-tight" style="color: var(--text-primary);">
              {article.data.title}
            </h3>
            <p class="mt-2 text-sm" style="color: var(--text-secondary);">{article.data.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <div class="surface-card-soft p-5 text-sm" style="color: var(--text-secondary);">
        No articles yet. Add markdown files in `src/content/articles/` and they will appear here.
      </div>
    )}
  </section>

  <section class="stagger-reveal surface-card-soft page-reveal mt-10 p-5 text-sm" style="color: var(--text-secondary); --stagger-delay: 540ms">
    <p class="display-font text-base font-semibold" style="color: var(--text-primary);">Getting Started</p>
    <p class="mt-1.5">
      Pick a module from the sidebar or the cards above. Each lesson contains documented C++ code with
      explanations, FAQs, common pitfalls, and runnable examples. Start with {" "}
      <a
        href={`/${firstLessonSlug}`}
        class="font-semibold underline decoration-2 underline-offset-2"
        style="color: var(--accent);"
      >
        Module 1: Fundamentals
      </a>{" "}
      if you're new to Modern C++.
    </p>
  </section>

  <div class="stagger-reveal" style="--stagger-delay: 600ms">
    <Footer authorName="Max Marino" authorUrl="https://www.maxthomarino.com/" />
  </div>
</DocLayout>
