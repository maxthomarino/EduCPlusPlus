---
import { getCollection } from "astro:content";
import DocLayout from "../layouts/DocLayout.astro";
import { buildSidebarData } from "../lib/sidebar-data.js";
import type { ParsedFile } from "../lib/types.js";
import { questions, TOPICS } from "../lib/questions";
import { programs as buggyPrograms } from "../lib/buggy-code";

const allLessons = await getCollection("lessons");
const allArticles = await getCollection(
  "articles",
  ({ data }) => import.meta.env.DEV || !data.draft
);
const sidebarData = buildSidebarData(allLessons.map((e) => e.data as unknown as ParsedFile));

const totalFiles = allLessons.length;
const totalModules = sidebarData.length;
const totalArticles = allArticles.length;
const latestArticles = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function getLevel(order: number): { label: string; cssClass: string } {
  if (order <= 4) return { label: "Beginner", cssClass: "level-beginner" };
  if (order <= 9) return { label: "Intermediate", cssClass: "level-intermediate" };
  return { label: "Advanced", cssClass: "level-advanced" };
}
---

<DocLayout
  title="EduC++ Documentation"
  description="Modern C++ educational documentation"
  sidebarData={sidebarData}
  currentSlug=""
>
  <!-- Hero -->
  <section class="lp-hero">
    <span class="lp-badge" style="animation-delay:60ms">Open-source learning platform</span>
    <h1 class="lp-title" style="animation-delay:100ms">
      Master Modern<br />
      <span class="lp-accent">C++</span>
    </h1>
    <p class="lp-desc" style="animation-delay:160ms">
      A structured path from core fundamentals to advanced features &mdash;
      focused explanations, runnable code, and clear decision-making guidance.
    </p>
    <div class="lp-actions" style="animation-delay:220ms">
      <a href={`/${sidebarData[0]?.subfolders[0]?.files[0]?.slug || ""}`} class="lp-btn-pri">
        Start Learning
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="/quiz" class="lp-btn-sec">Take the Quiz</a>
    </div>
    <div class="lp-stats">
      <div class="lp-stat lp-stat--accent" style="animation-delay:260ms">
        <span class="lp-stat-num">{totalFiles}</span>
        <span class="lp-stat-lbl">Lessons</span>
      </div>
      <div class="lp-stat lp-stat--accent" style="animation-delay:300ms">
        <span class="lp-stat-num">{totalModules}</span>
        <span class="lp-stat-lbl">Modules</span>
      </div>
      <div class="lp-stat lp-stat--deep" style="animation-delay:340ms">
        <span class="lp-stat-num">{totalArticles}</span>
        <span class="lp-stat-lbl">Articles</span>
      </div>
      <div class="lp-stat lp-stat--deep" style="animation-delay:380ms">
        <span class="lp-stat-num">{questions.length}</span>
        <span class="lp-stat-lbl">Quiz Qs</span>
      </div>
      <div class="lp-stat lp-stat--warn" style="animation-delay:420ms">
        <span class="lp-stat-num">{buggyPrograms.length}</span>
        <span class="lp-stat-lbl">Bug Challenges</span>
      </div>
    </div>
  </section>

  <!-- Quick Access -->
  <div class="lp-quick" style="animation-delay:360ms">
    <a href="/articles" class="lp-qcard">
      <div class="lp-qcard-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
      </div>
      <div class="min-w-0">
        <p class="lp-qcard-title">Editorial Articles</p>
        <p class="lp-qcard-sub">Deep dives beyond the lesson path</p>
      </div>
      <span class="lp-qcard-arrow">&rarr;</span>
    </a>
    <a href="/quiz" class="lp-qcard">
      <div class="lp-qcard-icon lp-qcard-icon--quiz">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
      </div>
      <div class="min-w-0">
        <p class="lp-qcard-title">C++ Quiz</p>
        <p class="lp-qcard-sub">{questions.length} questions across {TOPICS.length} topics</p>
      </div>
      <span class="lp-qcard-arrow">&rarr;</span>
    </a>
    <a href="/buggy-code" class="lp-qcard">
      <div class="lp-qcard-icon lp-qcard-icon--bug">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m8 2 1.88 1.88"/><path d="M14.12 3.88 16 2"/><path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1"/><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6"/><path d="M12 20v-9"/><path d="M6.53 9C4.6 8.8 3 7.1 3 5"/><path d="M6 13H2"/><path d="M3 21c0-2.1 1.7-3.9 3.8-4"/><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"/><path d="M22 13h-4"/><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"/></svg>
      </div>
      <div class="min-w-0">
        <p class="lp-qcard-title">Spot the Bug</p>
        <p class="lp-qcard-sub">{buggyPrograms.length} buggy programs to debug</p>
      </div>
      <span class="lp-qcard-arrow">&rarr;</span>
    </a>
  </div>

  <!-- Modules -->
  <section class="lp-modules" style="animation-delay:400ms">
    <div class="lp-sec-hdr">
      <h2 class="lp-sec-title">Explore Modules</h2>
      <span class="lp-sec-sub">{totalModules} modules &middot; {totalFiles} lessons</span>
    </div>
    <div class="lp-mod-grid">
      {sidebarData.map((mod, i) => {
        const firstFile = mod.subfolders[0]?.files[0];
        const fileCount = mod.subfolders.reduce((sum, sub) => sum + sub.files.length, 0);
        const level = getLevel(mod.order);
        return (
          <a
            href={firstFile ? `/${firstFile.slug}` : "#"}
            class={`lp-mod ${level.cssClass}`}
            style={`animation-delay:${60 + i * 30}ms`}
          >
            <div class="lp-mod-top">
              <span class="lp-mod-num">{String(mod.order).padStart(2, "0")}</span>
              <span class={`lp-mod-lvl ${level.cssClass}`}>{level.label}</span>
            </div>
            <h3 class="lp-mod-name">{mod.title}</h3>
            <p class="lp-mod-meta">
              {fileCount} {fileCount === 1 ? "lesson" : "lessons"}<span class="lp-sep">&middot;</span>{mod.subfolders.map((s) => s.name.replace(/_/g, " ")).join(", ")}
            </p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Getting Started -->
  <section class="lp-start" style="animation-delay:480ms">
    <div class="lp-start-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    </div>
    <div>
      <p class="lp-start-title">New to Modern C++?</p>
      <p class="lp-start-text">
        Start with{" "}
        <a
          href={`/${sidebarData[0]?.subfolders[0]?.files[0]?.slug || ""}`}
          class="lp-start-link"
        >Module 1: Fundamentals</a>{" "}
        &mdash; each lesson includes documented code, explanations, FAQs,
        common pitfalls, and runnable examples.
      </p>
    </div>
  </section>

  <!-- Latest Articles -->
  {latestArticles.length > 0 && (
    <section class="lp-articles" style="animation-delay:520ms">
      <div class="lp-sec-hdr">
        <h2 class="lp-sec-title">Latest Articles</h2>
        <a href="/articles" class="lp-sec-link">View all &rarr;</a>
      </div>
      <div class="lp-art-grid">
        {latestArticles.map((article, i) => (
          <a
            href={`/articles/${article.slug}`}
            class="lp-art"
            style={`animation-delay:${60 + i * 40}ms`}
          >
            <time class="lp-art-date">{formatDate(article.data.publishDate)}</time>
            <h3 class="lp-art-title">{article.data.title}</h3>
            <p class="lp-art-desc">{article.data.description}</p>
            <span class="lp-art-author">{article.data.author}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <footer class="lp-footer">
    Built by <a href="https://www.maxthomarino.com/" class="lp-footer-link">Max Marino</a>
  </footer>
</DocLayout>

<style>
  /* ========== LANDING PAGE ========== */

  /* --- Hero --- */
  .lp-hero {
    padding: 1.5rem 0 2rem;
  }

  @media (min-width: 640px) {
    .lp-hero {
      padding: 2rem 0 2.5rem;
    }
  }

  .lp-badge {
    display: inline-flex;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 0.22rem 0.6rem;
    border-radius: 0.3rem;
    border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--border-soft));
    background: color-mix(in srgb, var(--accent-soft) 30%, var(--surface-elevated));
    margin-bottom: 1.2rem;
    animation: lp-up 420ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .lp-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    animation: lp-up 460ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .lp-accent {
    background: linear-gradient(
      135deg,
      var(--accent) 0%,
      var(--deep) 60%,
      color-mix(in srgb, var(--accent) 70%, var(--success)) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    padding-right: 0.05em;
  }

  .lp-desc {
    margin-top: 1rem;
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 500px;
    animation: lp-up 460ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  /* Stats row */
  .lp-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 2rem;
  }

  .lp-stat {
    animation: lp-up 400ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
    padding: 0.5rem 0.8rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border-soft);
    background: var(--surface-elevated);
    min-width: 68px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .lp-stat::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    opacity: 0.6;
  }

  .lp-stat--accent::before { background: var(--accent); }
  .lp-stat--deep::before { background: var(--deep); }
  .lp-stat--warn::before { background: var(--warning); }
  .lp-stat--success::before { background: var(--success); }

  .lp-stat-num {
    display: block;
    font-family: var(--font-code);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text-primary);
  }

  .lp-stat-lbl {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* CTA buttons */
  .lp-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.6rem;
    animation: lp-up 460ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .lp-btn-pri {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.25rem;
    font-size: 0.84rem;
    font-weight: 650;
    border-radius: 0.5rem;
    background: var(--accent);
    color: #fff;
    box-shadow: 0 1px 6px -2px color-mix(in srgb, var(--accent) 30%, transparent);
    transition: transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.18s ease, filter 0.18s ease;
  }

  .lp-btn-pri:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px -4px color-mix(in srgb, var(--accent) 40%, transparent);
    filter: brightness(1.08);
  }

  .lp-btn-sec {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.25rem;
    font-size: 0.84rem;
    font-weight: 650;
    border-radius: 0.5rem;
    border: 1px solid var(--border-soft);
    background: var(--surface-elevated);
    color: var(--text-primary);
    transition: border-color 0.18s ease, color 0.18s ease;
  }

  .lp-btn-sec:hover {
    border-color: var(--border-strong);
    color: var(--accent);
  }

  /* --- Quick Access --- */
  .lp-quick {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    margin-bottom: 2.2rem;
    animation: lp-up 460ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  @media (min-width: 480px) {
    .lp-quick { grid-template-columns: 1fr 1fr 1fr; }
  }

  .lp-qcard {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.75rem 0.9rem;
    border-radius: 0.55rem;
    border: 1px solid var(--border-soft);
    background: var(--surface-elevated);
    position: relative;
    overflow: hidden;
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .lp-qcard::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .lp-qcard:nth-child(1)::before { background: var(--accent); }
  .lp-qcard:nth-child(2)::before { background: var(--deep); }
  .lp-qcard:nth-child(3)::before { background: var(--warning); }

  .lp-qcard:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
    border-color: var(--border-strong);
  }

  .lp-qcard:hover::before {
    opacity: 0.7;
  }

  .lp-qcard-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 0.45rem;
    flex-shrink: 0;
    color: var(--accent);
    background: var(--accent-soft);
  }

  .lp-qcard-icon svg {
    width: 16px;
    height: 16px;
  }

  .lp-qcard-icon--quiz {
    color: var(--deep);
    background: var(--deep-soft);
  }

  .lp-qcard-icon--bug {
    color: var(--warning);
    background: var(--warning-soft);
  }

  .lp-qcard-title {
    font-family: var(--font-display);
    font-size: 0.84rem;
    font-weight: 660;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .lp-qcard-sub {
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-top: 0.05rem;
    line-height: 1.3;
  }

  .lp-qcard-arrow {
    margin-left: auto;
    font-size: 0.85rem;
    color: var(--text-muted);
    flex-shrink: 0;
    opacity: 0;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }

  .lp-qcard:hover .lp-qcard-arrow {
    transform: translateX(2px);
    opacity: 1;
    color: var(--accent);
  }

  /* --- Modules --- */
  .lp-modules {
    margin-bottom: 2.2rem;
    animation: lp-up 460ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .lp-sec-hdr {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
    flex-wrap: wrap;
  }

  .lp-sec-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-primary);
  }

  .lp-sec-sub {
    font-family: var(--font-code);
    font-size: 0.68rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .lp-sec-link {
    font-size: 0.78rem;
    font-weight: 620;
    color: var(--accent);
    transition: opacity 0.15s ease;
  }

  .lp-sec-link:hover { opacity: 0.7; }

  .lp-mod-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }

  @media (min-width: 480px) {
    .lp-mod-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 720px) {
    .lp-mod-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  .lp-mod {
    display: block;
    padding: 0.7rem 0.85rem 0.7rem 0.95rem;
    border-radius: 0.55rem;
    border: 1px solid var(--border-soft);
    background: var(--surface-elevated);
    position: relative;
    overflow: hidden;
    animation: lp-up 380ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.2s ease, border-color 0.2s ease;
  }

  /* Colored left accent bar */
  .lp-mod::before {
    content: "";
    position: absolute;
    left: 0;
    top: 12%;
    bottom: 12%;
    width: 2.5px;
    border-radius: 0 2px 2px 0;
    opacity: 0.45;
    transition: opacity 0.2s ease, top 0.2s ease, bottom 0.2s ease;
  }

  .lp-mod.level-beginner::before { background: var(--success); }
  .lp-mod.level-intermediate::before { background: var(--warning); }
  .lp-mod.level-advanced::before { background: var(--deep); }

  .lp-mod:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    border-color: var(--border-strong);
  }

  .lp-mod:hover::before {
    opacity: 1;
    top: 0;
    bottom: 0;
  }

  .lp-mod-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.45rem;
  }

  .lp-mod-num {
    font-family: var(--font-code);
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    opacity: 0.6;
  }

  .lp-mod-lvl {
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.1rem 0.38rem;
    border-radius: 0.25rem;
  }

  .lp-mod-lvl.level-beginner { color: var(--success); background: var(--success-soft); }
  .lp-mod-lvl.level-intermediate { color: var(--warning); background: var(--warning-soft); }
  .lp-mod-lvl.level-advanced { color: var(--deep); background: var(--deep-soft); }

  .lp-mod-name {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 660;
    letter-spacing: -0.015em;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .lp-mod-meta {
    margin-top: 0.25rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lp-sep {
    margin: 0 0.25rem;
    opacity: 0.35;
  }

  /* --- Getting Started --- */
  .lp-start {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.7rem 0.9rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--accent-soft) 15%, var(--surface-elevated));
    border: 1px solid color-mix(in srgb, var(--accent) 10%, var(--border-soft));
    border-left: 2.5px solid color-mix(in srgb, var(--accent) 45%, transparent);
    margin-bottom: 2rem;
    animation: lp-up 460ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .lp-start-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 0.4rem;
    background: var(--accent);
    color: #fff;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .lp-start-icon svg {
    width: 14px;
    height: 14px;
  }

  .lp-start-title {
    font-family: var(--font-display);
    font-weight: 660;
    font-size: 0.88rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .lp-start-text {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-top: 0.1rem;
    line-height: 1.55;
  }

  .lp-start-link {
    color: var(--accent);
    font-weight: 650;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    transition: border-color 0.15s ease;
  }

  .lp-start-link:hover { border-color: var(--accent); }

  /* --- Articles --- */
  .lp-articles {
    margin-bottom: 2.2rem;
    animation: lp-up 460ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .lp-art-grid {
    display: grid;
