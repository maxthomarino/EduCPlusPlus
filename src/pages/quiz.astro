---
import BaseLayout from "../layouts/BaseLayout.astro";
import FlashcardQuiz from "../components/quiz/FlashcardQuiz.tsx";
import { questions, TOPICS } from "../lib/questions";
const totalQuestions = questions.length;
const totalTopics = TOPICS.length;
---

<BaseLayout title="C++ Quiz" description={`Test your C++ knowledge with ${totalQuestions} multiple choice questions across ${totalTopics} topics.`}>
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <div class="page-reveal mb-6">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-[0.78rem] font-medium transition-opacity hover:opacity-70"
        style="color: var(--text-muted);"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Home
      </a>
      <h1 class="display-font mt-2.5 text-[clamp(1.6rem,3.5vw,2.2rem)] font-bold" style="letter-spacing: -0.03em; color: var(--text-primary); line-height: 1.1;">
        C++ <span class="gradient-title">Quiz</span>
      </h1>
      <p class="mt-1" style="color: var(--text-secondary); font-size: 0.86rem; line-height: 1.6;">
        <span style="font-family: var(--font-code); font-weight: 600; color: var(--accent); font-size: 0.82rem;">{totalQuestions}</span> questions across
        <span style="font-family: var(--font-code); font-weight: 600; color: var(--accent); font-size: 0.82rem;">{totalTopics}</span> topics.
        Select topics and difficulty, then start.
      </p>
    </div>
    <FlashcardQuiz client:load />
  </main>
</BaseLayout>
