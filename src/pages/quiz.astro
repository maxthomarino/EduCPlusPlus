---
import BaseLayout from "../layouts/BaseLayout.astro";
import FlashcardQuiz from "../components/quiz/FlashcardQuiz.tsx";
---

<BaseLayout title="C++ Quiz" description="Test your C++ knowledge with 128 multiple choice questions across 15 topics.">
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <div class="page-reveal mb-6">
      <a
        href="/"
        class="text-sm font-medium"
        style="color: var(--accent);"
      >
        ← Back to home
      </a>
      <h1 class="display-font mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">
        <span style="color: var(--text-primary);">C++ </span>
        <span class="gradient-title">Quiz</span>
      </h1>
      <p class="mt-2 text-base" style="color: var(--text-secondary);">
        Test your knowledge with 128 multiple choice questions across 15 topics.
        Select topics and difficulty, then work through the flashcards.
      </p>
    </div>
    <FlashcardQuiz client:load />
  </main>
</BaseLayout>
