---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const allArticles = await getCollection(
    "articles",
    ({ data }) => import.meta.env.DEV || !data.draft
  );

  return allArticles.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"articles"> };
const { Content } = await render(entry);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <main class="mx-auto max-w-[680px] px-4 py-8 sm:px-6">
    <div class="page-reveal mb-6">
      <a
        href="/articles"
        class="inline-flex items-center gap-1 text-[0.78rem] font-medium transition-opacity hover:opacity-70"
        style="color: var(--text-muted);"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Articles
      </a>
    </div>

    <article class="page-reveal">
      <div class="art-header">
        <div class="art-header-meta">
          <time>{formatDate(entry.data.publishDate)}</time>
          <span class="art-header-dot">·</span>
          <span>{entry.data.author}</span>
        </div>
        <h1 class="art-header-title">
          {entry.data.title}
        </h1>
        <p class="art-header-desc">
          {entry.data.description}
        </p>
        {entry.data.tags.length > 0 && (
          <div class="art-header-tags">
            {entry.data.tags.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <div class="article-content">
        <Content />
      </div>
    </article>

    <nav class="art-footer">
      <a href="/articles" class="art-footer-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        All Articles
      </a>
      <a href="/" class="art-footer-link">
        Home
      </a>
    </nav>
  </main>
</BaseLayout>

<style>
  .art-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .art-header-meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .art-header-dot {
    opacity: 0.4;
  }

  .art-header-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 750;
    letter-spacing: -0.03em;
    line-height: 1.12;
    color: var(--text-primary);
  }

  .art-header-desc {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .art-header-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.6rem;
  }

  .art-footer {
    display: flex;
    gap: 0.6rem;
    padding-top: 1.25rem;
    margin-top: 2rem;
    border-top: 1px solid var(--border-soft);
  }

  .art-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.76rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 0.15s ease;
  }

  .art-footer-link:hover {
    color: var(--accent);
  }
</style>

<style is:global>
  .article-content h2 {
    margin-top: 1.6rem;
    margin-bottom: 0.4rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .article-content h3 {
    margin-top: 1.2rem;
    margin-bottom: 0.35rem;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--text-primary);
  }

  .article-content p {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .article-content ul,
  .article-content ol {
    margin-top: 0.6rem;
    padding-left: 1.2rem;
  }

  .article-content li {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .article-content code {
    font-size: 0.82rem;
    padding: 0.12rem 0.35rem;
    border-radius: 0.25rem;
    background: var(--surface-muted);
    color: var(--text-primary);
    font-weight: 500;
  }

  .article-content blockquote {
    margin: 1rem 0;
    padding: 0.6rem 1rem;
    border-left: 2.5px solid var(--accent);
    background: color-mix(in srgb, var(--accent-soft) 20%, var(--surface-elevated));
    border-radius: 0 0.4rem 0.4rem 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .article-content a {
    color: var(--accent);
    font-weight: 550;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    transition: border-color 0.15s ease;
  }

  .article-content a:hover {
    border-color: var(--accent);
  }
</style>
