---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allArticles = await getCollection(
  "articles",
  ({ data }) => import.meta.env.DEV || !data.draft
);
const articles = allArticles.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title="C++ Articles" description="Editorial-style C++ articles and notes">
  <main class="mx-auto max-w-4xl px-5 py-10 sm:px-7">
    <section class="surface-card page-reveal p-6 sm:p-8">
      <p class="eyebrow mb-2">Article Library</p>
      <h1 class="display-font text-4xl font-semibold tracking-tight" style="color: var(--text-primary);">
        C++ Articles
      </h1>
      <p class="mt-3 max-w-2xl text-base sm:text-lg" style="color: var(--text-secondary);">
        Blog-style writing about practical C++, design decisions, and engineering tradeoffs.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="/" class="metric-pill hover-lift">Back to Docs Home</a>
      </div>
    </section>

    {articles.length > 0 ? (
      <section class="mt-6 space-y-4">
        {articles.map((article) => (
          <a href={`/articles/${article.slug}`} class="surface-card hover-lift page-reveal block p-5">
            <p class="text-xs font-medium tracking-[0.06em]" style="color: var(--text-muted);">
              {formatDate(article.data.publishDate)} - {article.data.author}
            </p>
            <h2 class="display-font mt-1 text-2xl font-semibold tracking-tight" style="color: var(--text-primary);">
              {article.data.title}
            </h2>
            <p class="mt-2 text-sm sm:text-base" style="color: var(--text-secondary);">
              {article.data.description}
            </p>
            {article.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {article.data.tags.map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </section>
    ) : (
      <section class="surface-card-soft mt-6 p-5 text-sm" style="color: var(--text-secondary);">
        No articles yet. Add markdown files under `src/content/articles/`.
      </section>
    )}
  </main>
</BaseLayout>
