---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allArticles = await getCollection(
  "articles",
  ({ data }) => import.meta.env.DEV || !data.draft
);
const articles = allArticles.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title="C++ Articles" description="Editorial-style C++ articles and notes">
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <div class="page-reveal mb-6">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-[0.78rem] font-medium transition-opacity hover:opacity-70"
        style="color: var(--text-muted);"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Home
      </a>
      <h1 class="display-font mt-2.5 text-[clamp(1.6rem,3.5vw,2.2rem)] font-bold" style="letter-spacing: -0.03em; color: var(--text-primary); line-height: 1.1;">
        Articles
      </h1>
      <p class="mt-1" style="color: var(--text-secondary); font-size: 0.86rem; line-height: 1.6;">
        Blog-style writing about practical C++, design decisions, and engineering tradeoffs.
      </p>
    </div>

    {articles.length > 0 ? (
      <section class="art-list">
        {articles.map((article) => (
          <a href={`/articles/${article.slug}`} class="art-card">
            <div class="art-card-header">
              <time class="art-card-date">{formatDate(article.data.publishDate)}</time>
              <span class="art-card-dot">·</span>
              <span class="art-card-author">{article.data.author}</span>
            </div>
            <h2 class="art-card-title">
              {article.data.title}
            </h2>
            <p class="art-card-desc">
              {article.data.description}
            </p>
            {article.data.tags.length > 0 && (
              <div class="art-card-tags">
                {article.data.tags.map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </section>
    ) : (
      <section class="surface-card-soft mt-6 p-5 text-sm" style="color: var(--text-secondary);">
        No articles yet.
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .art-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .art-card {
    display: block;
    padding: 0.8rem 0.95rem;
    border-radius: 0.55rem;
    border: 1px solid var(--border-soft);
    border-left: 2.5px solid transparent;
    background: var(--surface-elevated);
    transition: transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.18s ease, border-color 0.18s ease, border-left-color 0.18s ease;
  }

  .art-card:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
    border-color: var(--border-strong);
    border-left-color: var(--accent);
  }

  .art-card-header {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .art-card-date {
    font-family: var(--font-code);
    font-size: 0.65rem;
    font-weight: 500;
  }

  .art-card-dot {
    opacity: 0.4;
  }

  .art-card-author {
    font-weight: 600;
  }

  .art-card-title {
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 660;
    letter-spacing: -0.015em;
    color: var(--text-primary);
    margin-top: 0.2rem;
    line-height: 1.25;
    transition: color 0.15s ease;
  }

  .art-card:hover .art-card-title {
    color: var(--accent);
  }

  .art-card-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .art-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.4rem;
  }
</style>
