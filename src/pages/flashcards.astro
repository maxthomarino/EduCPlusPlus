---
import BaseLayout from "../layouts/BaseLayout.astro";
import EquationFlashcards from "../components/flashcards/EquationFlashcards.tsx";
import { flashcards, FLASHCARD_TOPICS } from "../lib/flashcards";
const totalCards = flashcards.length;
const totalTopics = FLASHCARD_TOPICS.length;
---

<BaseLayout title="Equation Flashcards" description={`Memorise ${totalCards} key equations across ${totalTopics} topics with flip-style flashcards.`}>
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <div class="page-reveal mb-6">
      <a
        href="/"
        class="text-sm font-medium"
        style="color: var(--accent);"
      >
        ← Back to home
      </a>
      <h1 class="display-font mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">
        <span style="color: var(--text-primary);">Equation </span>
        <span class="gradient-title">Flashcards</span>
      </h1>
      <p class="mt-2 text-base" style="color: var(--text-secondary);">
        {totalCards} equations across {totalTopics} {totalTopics === 1 ? "topic" : "topics"}.
        Flip cards to reveal formulas and build recall.
      </p>
    </div>
    <EquationFlashcards client:load />
  </main>
</BaseLayout>
