---
import BaseLayout from "../layouts/BaseLayout.astro";
import BuggyCodeViewer from "../components/buggy-code/BuggyCodeViewer.tsx";
import { programs, BUGGY_TOPICS, learningPaths, pathGroups } from "../lib/buggy-code";
import type { BuggyProgramHighlighted } from "../lib/buggy-code";
import { createHighlighter } from "shiki";

const highlighter = await createHighlighter({
  themes: ["github-dark"],
  langs: ["cpp"],
});

const highlighted: BuggyProgramHighlighted[] = programs.map((p) => ({
  ...p,
  highlightedHtml: highlighter.codeToHtml(p.code, {
    lang: "cpp",
    theme: "github-dark",
  }),
}));

highlighter.dispose();

const totalPrograms = programs.length;
const totalTopics = BUGGY_TOPICS.length;
---

<BaseLayout title="Spot the Bug" description={`Read ${totalPrograms} buggy C++ programs across ${totalTopics} topics and find the hidden bug.`}>
  <main class="mx-auto px-4 py-8 sm:px-6" style="max-width: 1400px;">
    <div class="page-reveal mb-6">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-[0.78rem] font-medium transition-opacity hover:opacity-70"
        style="color: var(--text-muted);"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Home
      </a>
      <h1 class="display-font mt-2.5 text-[clamp(1.6rem,3.5vw,2.2rem)] font-bold" style="letter-spacing: -0.03em; color: var(--text-primary); line-height: 1.1;">
        Spot the <span class="gradient-title">Bug</span>
      </h1>
      <p class="mt-1" style="color: var(--text-secondary); font-size: 0.86rem; line-height: 1.6;">
        <span style="font-family: var(--font-code); font-weight: 600; color: var(--accent); font-size: 0.82rem;">{totalPrograms}</span> buggy programs across
        <span style="font-family: var(--font-code); font-weight: 600; color: var(--accent); font-size: 0.82rem;">{totalTopics}</span> topics.
        Each compiles cleanly but contains exactly one subtle bug.
      </p>
    </div>
    <BuggyCodeViewer client:load programs={highlighted} paths={learningPaths} pathGroups={pathGroups} />
  </main>
</BaseLayout>
