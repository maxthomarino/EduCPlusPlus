---
import { Code } from "astro:components";

interface Props {
  code: string;
  language?: string;
}

const { code, language = "cpp" } = Astro.props;
const trimmedCode = code.trim();
const lang = language === "cmake" ? "cmake" : "cpp";
const langLabel = lang === "cmake" ? "CMake" : "C++";
---

{trimmedCode && (
  <div class="cb">
    <div class="cb-accent" aria-hidden="true"></div>
    <div class="cb-header">
      <span class="cb-lang">{langLabel}</span>
      <button
        class="cb-copy"
        data-code={trimmedCode}
        type="button"
      >
        <svg class="cb-copy-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        <span class="cb-copy-label">Copy</span>
      </button>
    </div>
    <Code code={trimmedCode} lang={lang} theme="github-dark" />
  </div>
)}

<script>
  document.querySelectorAll(".cb-copy").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const code = (btn as HTMLElement).dataset.code || "";
      await navigator.clipboard.writeText(code);
      const label = btn.querySelector(".cb-copy-label");
      if (label) {
        const original = label.textContent;
        label.textContent = "Copied!";
        setTimeout(() => (label.textContent = original), 1500);
      }
    });
  });
</script>

<style>
  .cb {
    position: relative;
    margin: 1.2rem 0;
    border-radius: 0.55rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: var(--surface-code);
    box-shadow: 0 1px 4px -1px rgba(0, 0, 0, 0.12), 0 1px 2px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    animation: sec-in 280ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .cb-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1.5px;
    background: linear-gradient(90deg, var(--accent), var(--deep) 60%, transparent);
    opacity: 0.5;
    z-index: 1;
  }

  .cb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.4rem 0.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }

  .cb-lang {
    font-family: var(--font-code);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
  }

  .cb-copy {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.22rem 0.45rem;
    border-radius: 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.65rem;
    font-weight: 550;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.16s ease, background 0.12s ease, color 0.12s ease;
  }

  .cb:hover .cb-copy {
    opacity: 1;
  }

  .cb-copy:hover {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
  }

  .cb-copy-icon {
    flex-shrink: 0;
  }

  @keyframes sec-in {
    from { opacity: 0; transform: translateY(3px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cb { animation: none; }
  }
</style>
