---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section id="key-takeaways" class="my-8 rounded-lg border-l-4 border-emerald-400 bg-emerald-50/50 p-5 dark:border-emerald-500 dark:bg-emerald-950/30">
    <h2 class="mb-3 flex items-center gap-2 text-lg font-bold text-emerald-800 dark:text-emerald-300">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Key Takeaways
    </h2>
    <ol class="space-y-1.5 text-[15px] leading-relaxed text-emerald-900/90 dark:text-emerald-200/90">
      {items.map((item) => (
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-emerald-500 dark:text-emerald-400">&#x2022;</span>
          <span>{item}</span>
        </li>
      ))}
    </ol>
  </section>
)}
