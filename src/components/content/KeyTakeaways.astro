---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section id="key-takeaways" class="kt scroll-mt-20">
    <h2 class="kt-heading">
      <svg class="kt-heading-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Key Takeaways
    </h2>
    <ol class="kt-list">
      {items.map((item) => (
        <li class="kt-item">
          <svg class="kt-check" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{item}</span>
        </li>
      ))}
    </ol>
  </section>
)}

<style>
  .kt {
    margin: 1.5rem 0;
    padding: 0.8rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--success) 10%, var(--border-soft));
    border-left: 2.5px solid color-mix(in srgb, var(--success) 45%, transparent);
    background: color-mix(in srgb, var(--success-soft) 25%, var(--surface-elevated));
    animation: sec-in 300ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .kt-heading {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--success);
    margin-bottom: 0.5rem;
  }

  .kt-heading-icon {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    opacity: 0.8;
  }

  .kt-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .kt-item {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-primary);
  }

  .kt-check {
    color: var(--success);
    flex-shrink: 0;
    margin-top: 0.2rem;
    opacity: 0.6;
    width: 12px;
    height: 12px;
  }

  @keyframes sec-in {
    from { opacity: 0; transform: translateY(3px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .kt { animation: none; }
  }
</style>
