---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <section
    id="key-takeaways"
    class="page-reveal my-8 rounded-2xl border-l-4 p-5"
    style="border-color: var(--success); background: color-mix(in srgb, var(--success-soft) 70%, var(--surface-elevated));"
  >
    <h2 class="callout-title mb-3 flex items-center gap-2 text-lg font-bold" style="color: var(--success);">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Key Takeaways
    </h2>
    <ol class="space-y-1.5 text-[15px] leading-relaxed" style="color: var(--text-primary);">
      {items.map((item) => (
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0" style="color: var(--success);">&bull;</span>
          <span>{item}</span>
        </li>
      ))}
    </ol>
  </section>
)}
