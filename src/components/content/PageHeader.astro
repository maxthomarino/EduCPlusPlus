---
import type { FileHeader } from "../../lib/types.js";

interface Props {
  header: FileHeader;
  moduleName: string;
  moduleTitle: string;
  subfolder: string;
}

const { header, moduleName, moduleTitle, subfolder } = Astro.props;
---

<div class="ph">
  <!-- Breadcrumb -->
  <nav class="ph-crumbs">
    <span class="ph-crumb">{moduleTitle}</span>
    <svg class="ph-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    <span class="ph-crumb">{subfolder.replace(/_/g, " ")}</span>
  </nav>

  <h1 class="ph-title">{header.shortTitle}</h1>

  {header.description && (
    <p
      class="ph-desc"
      set:html={header.description.replace(/\n\n/g, "<br/><br/>").replace(/\n/g, " ")}
    />
  )}

  {(header.prerequisites || header.standard) && (
    <div class="ph-meta">
      {header.prerequisites && (
        <div class="ph-meta-item">
          <svg class="ph-meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          <span class="ph-meta-label">Prerequisites</span>
          <span class="ph-meta-value">{header.prerequisites}</span>
        </div>
      )}
      {header.standard && (
        <div class="ph-meta-item">
          <svg class="ph-meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          <span class="ph-meta-label">Standard</span>
          <span class="ph-meta-value">{header.standard}</span>
        </div>
      )}
    </div>
  )}

  <div class="ph-rule" aria-hidden="true"></div>
</div>

<style>
  .ph {
    margin-bottom: 2.5rem;
    animation: ph-in 400ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .ph-crumbs {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 1rem;
    font-size: 0.78rem;
    font-weight: 550;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .ph-crumb {
    text-transform: capitalize;
  }

  .ph-sep {
    color: var(--border-strong);
    flex-shrink: 0;
  }

  .ph-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--text-primary);
  }

  .ph-desc {
    margin-top: 0.9rem;
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 640px;
  }

  .ph-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }

  .ph-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.38rem 0.7rem;
    border-radius: 0.55rem;
    border: 1px solid var(--border-soft);
    background: color-mix(in srgb, var(--surface-muted) 50%, var(--surface-elevated));
    font-size: 0.82rem;
  }

  .ph-meta-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .ph-meta-label {
    font-weight: 600;
    color: var(--text-muted);
  }

  .ph-meta-value {
    color: var(--text-primary);
    font-weight: 520;
  }

  .ph-rule {
    margin-top: 1.6rem;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent) 35%, var(--border-soft)) 0%,
      color-mix(in srgb, var(--deep) 25%, var(--border-soft)) 50%,
      transparent 100%
    );
    opacity: 0.7;
  }

  @keyframes ph-in {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ph { animation: none; }
  }
</style>
