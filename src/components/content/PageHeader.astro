---
import type { FileHeader } from "../../lib/types.js";

interface Props {
  header: FileHeader;
  moduleName: string;
  moduleTitle: string;
  subfolder: string;
}

const { header, moduleName, moduleTitle, subfolder } = Astro.props;
---

<div class="page-reveal mb-9">
  <!-- Breadcrumb -->
  <nav class="mb-4 flex flex-wrap items-center gap-2 text-xs">
    <span class="chip">{moduleName}</span>
    <span class="chip">{moduleTitle}</span>
    <span class="chip">{subfolder.replace(/_/g, " ")}</span>
  </nav>

  <h1 class="display-font text-3xl font-semibold tracking-tight sm:text-[2.15rem]" style="color: var(--text-primary);">
    {header.shortTitle}
  </h1>

  {header.description && (
    <p
      class="mt-3 max-w-3xl text-base leading-relaxed sm:text-lg"
      style="color: var(--text-secondary);"
      set:html={header.description.replace(/\n\n/g, "<br/><br/>").replace(/\n/g, " ")}
    />
  )}

  <!-- Metadata cards -->
  <div class="mt-5 flex flex-wrap gap-2.5">
    {header.prerequisites && (
      <div class="surface-card-soft inline-flex items-center gap-2 px-3 py-2 text-sm">
        <span class="font-medium" style="color: var(--text-muted);">Prerequisites</span>
        <span style="color: var(--text-primary);">{header.prerequisites}</span>
      </div>
    )}
    {header.standard && (
      <div class="surface-card-soft inline-flex items-center gap-2 px-3 py-2 text-sm">
        <span class="font-medium" style="color: var(--text-muted);">Standard</span>
        <span style="color: var(--text-primary);">{header.standard}</span>
      </div>
    )}
  </div>
</div>
