---
interface Props {
  title: string;
  content: string;
}

const { title, content } = Astro.props;
---

<section id="decision-guide" class="my-8 rounded-lg border border-gray-200 bg-gray-50 p-5 dark:border-slate-700 dark:bg-slate-800/50">
  <h2 class="mb-3 flex items-center gap-2 text-lg font-bold text-gray-900 dark:text-slate-100">
    <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
    </svg>
    {title}
  </h2>
  <pre class="whitespace-pre-wrap font-sans text-[15px] leading-relaxed text-gray-900 dark:text-slate-200" set:text={content} />
</section>
