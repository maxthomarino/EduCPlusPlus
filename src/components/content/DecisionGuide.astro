---
interface Props {
  title: string;
  content: string;
}

const { title, content } = Astro.props;
---

<section
  id="decision-guide"
  class="page-reveal my-8 rounded-2xl border p-5"
  style="border-color: var(--border-soft); background: color-mix(in srgb, var(--surface-muted) 64%, var(--surface-elevated));"
>
  <h2 class="callout-title mb-3 flex items-center gap-2 text-lg font-bold" style="color: var(--text-primary);">
    <svg class="h-5 w-5" style="color: var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
    </svg>
    {title}
  </h2>
  <pre class="whitespace-pre-wrap font-sans text-[15px] leading-relaxed" style="color: var(--text-secondary);" set:text={content} />
</section>
