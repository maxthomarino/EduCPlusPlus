---
interface Props {
  content: string;
}

const { content } = Astro.props;
---

<div
  class="page-reveal my-4 rounded-r-2xl border-l-4 px-4 py-3"
  style="border-color: var(--warning); background: color-mix(in srgb, var(--warning-soft) 78%, var(--surface-elevated));"
>
  <p class="text-[15px] leading-relaxed" style="color: var(--text-primary);">
    <span class="font-bold" style="color: var(--warning);">Watch out:</span>{" "}
    {content}
  </p>
</div>
