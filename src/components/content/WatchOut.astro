---
interface Props {
  content: string;
}

const { content } = Astro.props;
---

<div class="my-4 rounded-r-lg border-l-4 border-amber-400 bg-amber-50 px-4 py-3 dark:border-amber-500 dark:bg-amber-950/30">
  <p class="text-[15px] leading-relaxed text-amber-900 dark:text-amber-200">
    <span class="font-bold">Watch out:</span>{" "}
    {content}
  </p>
</div>
