---
interface Props {
  title: string;
  content: string;
  id?: string;
}

const { title, content, id } = Astro.props;

function slugifyId(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").substring(0, 60);
}
---

<details
  id={id || slugifyId(title)}
  class="page-reveal my-6 overflow-hidden rounded-2xl border-l-4"
  style="border-color: var(--deep); background: color-mix(in srgb, var(--deep-soft) 68%, var(--surface-elevated));"
>
  <summary class="flex cursor-pointer items-center gap-2 px-4 py-3 text-[15px] font-bold" style="color: var(--deep);">
    <svg class="chevron h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="callout-title">{title}</span>
    <span class="ml-auto text-[10px] font-bold uppercase tracking-[0.12em]" style="color: color-mix(in srgb, var(--deep) 78%, black);">
      Deep Dive
    </span>
  </summary>
  <div class="px-4 pb-4 pl-10">
    <pre class="whitespace-pre-wrap font-sans text-[15px] leading-relaxed" style="color: var(--text-primary);" set:text={content} />
  </div>
</details>
