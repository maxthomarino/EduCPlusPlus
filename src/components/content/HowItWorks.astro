---
interface Props {
  title: string;
  content: string;
  id?: string;
}

const { title, content, id } = Astro.props;

function slugifyId(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").substring(0, 60);
}
---

<details
  id={id || slugifyId(title)}
  class="hiw"
>
  <summary class="hiw-summary">
    <svg class="hiw-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    <span class="hiw-title">{title}</span>
    <span class="hiw-badge">Deep Dive</span>
    <svg class="hiw-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
  </summary>
  <div class="hiw-body">
    <pre class="hiw-content" set:text={content} />
  </div>
</details>

<style>
  .hiw {
    margin: 1.2rem 0;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--deep) 12%, var(--border-soft));
    border-left: 2.5px solid color-mix(in srgb, var(--deep) 45%, transparent);
    background: color-mix(in srgb, var(--deep-soft) 28%, var(--surface-elevated));
    overflow: hidden;
    animation: sec-in 300ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .hiw-summary {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.8rem;
    cursor: pointer;
    list-style: none;
    transition: background 0.15s ease;
  }

  .hiw-summary::-webkit-details-marker { display: none; }
  .hiw-summary::marker { display: none; content: ""; }

  .hiw-summary:hover {
    background: color-mix(in srgb, var(--deep-soft) 25%, transparent);
  }

  .hiw-icon {
    color: var(--deep);
    flex-shrink: 0;
    opacity: 0.7;
  }

  .hiw-title {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 650;
    color: var(--deep);
    flex: 1;
    min-width: 0;
  }

  .hiw-badge {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    background: var(--deep-soft);
    color: var(--deep);
    flex-shrink: 0;
  }

  .hiw-chevron {
    color: var(--deep);
    flex-shrink: 0;
    opacity: 0.5;
    transition: transform 0.22s ease;
  }

  .hiw[open] .hiw-chevron {
    transform: rotate(90deg);
  }

  .hiw-body {
    padding: 0 0.8rem 0.75rem 2.2rem;
  }

  .hiw-content {
    white-space: pre-wrap;
    font-family: var(--font-body);
    font-size: 0.84rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  @keyframes sec-in {
    from { opacity: 0; transform: translateY(3px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hiw { animation: none; }
  }
</style>
