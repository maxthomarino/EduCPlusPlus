---
interface Props {
  title: string;
  content: string;
  id?: string;
}

const { title, content, id } = Astro.props;

function slugifyId(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").substring(0, 60);
}

function toParagraphs(text: string): string[] {
  return text
    .split(/\n\s*\n/g)
    .map((paragraph) =>
      paragraph
        .split("\n")
        .map((line) => line.trim())
        .filter(Boolean)
        .join(" ")
        .replace(/\s{2,}/g, " ")
        .trim()
    )
    .filter(Boolean);
}

const paragraphs = toParagraphs(content);
---

<section id={id || slugifyId(title)} class="gs scroll-mt-20">
  <h2 class="gs-heading">{title}</h2>
  {paragraphs.length > 0 && (
    <div class="gs-body">
      {paragraphs.map((paragraph) => (
        <p class="gs-para">{paragraph}</p>
      ))}
    </div>
  )}
</section>

<style>
  .gs {
    margin: 2.2rem 0;
    animation: sec-in 360ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .gs-heading {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 0.65rem;
  }

  .gs-body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .gs-para {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  @keyframes sec-in {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .gs { animation: none; }
  }
</style>
