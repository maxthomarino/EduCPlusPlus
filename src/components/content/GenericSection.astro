---
interface Props {
  title: string;
  content: string;
  id?: string;
}

const { title, content, id } = Astro.props;

function slugifyId(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").substring(0, 60);
}

function toParagraphs(text: string): string[] {
  return text
    .split(/\n\s*\n/g)
    .map((paragraph) =>
      paragraph
        .split("\n")
        .map((line) => line.trim())
        .filter(Boolean)
        .join(" ")
        .replace(/\s{2,}/g, " ")
        .trim()
    )
    .filter(Boolean);
}

const paragraphs = toParagraphs(content);
---

<section id={id || slugifyId(title)} class="page-reveal my-8 scroll-mt-20">
  <h2 class="display-font mb-3 text-2xl font-bold tracking-tight" style="color: var(--text-primary);">{title}</h2>
  {paragraphs.length > 0 && (
    <div class="space-y-3 text-[15px] leading-relaxed" style="color: var(--text-secondary);">
      {paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  )}
</section>
