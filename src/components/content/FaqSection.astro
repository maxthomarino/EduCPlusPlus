---
interface Props {
  questions: { question: string; answer: string }[];
}

const { questions } = Astro.props;
---

{questions.length > 0 && (
  <section id="faq" class="my-8">
    <h2 class="mb-4 text-xl font-bold text-gray-900 dark:text-slate-100">Frequently Asked Questions</h2>
    <div class="space-y-2">
      {questions.map((qa) => (
        <details class="group rounded-lg border border-gray-200 transition-colors open:border-blue-200 open:bg-blue-50/30 dark:border-slate-700 dark:open:border-blue-800 dark:open:bg-blue-950/30">
          <summary class="flex cursor-pointer items-center gap-2 px-4 py-3 text-[15px] font-semibold text-gray-800 dark:text-slate-200">
            <svg class="chevron h-4 w-4 shrink-0 text-gray-400 transition-transform group-open:rotate-90 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            {qa.question}
          </summary>
          <div class="px-4 pb-4 pl-10 text-[15px] leading-relaxed text-gray-900 dark:text-slate-200">
            {qa.answer}
          </div>
        </details>
      ))}
    </div>
  </section>
)}
