---
interface Props {
  questions: { question: string; answer: string }[];
}

const { questions } = Astro.props;
---

{questions.length > 0 && (
  <section id="faq" class="faq scroll-mt-20">
    <h2 class="faq-heading">
      <svg class="faq-heading-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
      Frequently Asked Questions
    </h2>
    <div class="faq-list">
      {questions.map((qa) => (
        <details class="faq-item">
          <summary class="faq-q">
            <span class="faq-q-badge">Q</span>
            <span class="faq-q-text">{qa.question}</span>
            <svg class="faq-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </summary>
          <div class="faq-a">
            <span class="faq-a-badge">A</span>
            <span class="faq-a-text">{qa.answer}</span>
          </div>
        </details>
      ))}
    </div>
  </section>
)}

<style>
  .faq {
    margin: 1.5rem 0;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-soft);
    animation: sec-in 300ms cubic-bezier(0.22, 0.8, 0.22, 1) both;
  }

  .faq-heading {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 0.55rem;
    padding-top: 0.4rem;
  }

  .faq-heading-icon {
    color: var(--accent);
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    opacity: 0.6;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .faq-item {
    border: 1px solid var(--border-soft);
    border-radius: 0.5rem;
    background: var(--surface-elevated);
    overflow: hidden;
    transition: box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .faq-item[open] {
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--accent) 15%, var(--border-soft));
  }

  .faq-q {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.8rem;
    cursor: pointer;
    list-style: none;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    transition: background 0.15s ease;
  }

  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::marker { display: none; content: ""; }

  .faq-q:hover {
    background: color-mix(in srgb, var(--surface-muted) 30%, transparent);
  }

  .faq-q-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 0.3rem;
    background: var(--accent-soft);
    color: var(--accent);
    font-family: var(--font-code);
    font-size: 0.58rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .faq-q-text {
    flex: 1;
    min-width: 0;
  }

  .faq-chevron {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.22s ease;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(90deg);
  }

  .faq-a {
    display: flex;
    gap: 0.5rem;
    padding: 0 0.8rem 0.65rem;
    font-size: 0.84rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .faq-a-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 0.3rem;
    background: var(--success-soft);
    color: var(--success);
    font-family: var(--font-code);
    font-size: 0.58rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .faq-a-text {
    flex: 1;
    min-width: 0;
  }

  @keyframes sec-in {
    from { opacity: 0; transform: translateY(3px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq { animation: none; }
  }
</style>
