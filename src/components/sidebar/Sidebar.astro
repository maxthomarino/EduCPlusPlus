---
import ModuleGroup from "./ModuleGroup.astro";
import type { SidebarModule } from "../../lib/types.js";

interface Props {
  modules: SidebarModule[];
  currentSlug: string;
}

const { modules, currentSlug } = Astro.props;
---

<div class="sidebar-scroll flex h-full flex-col overflow-y-auto">
  <!-- Logo / title + theme toggle -->
  <div class="border-b px-4 py-4" style="border-color: var(--border-soft);">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <a href="/" class="group inline-flex items-center gap-2 text-lg font-semibold">
          <svg class="h-7 w-7 shrink-0" viewBox="0 0 64 64" fill="none">
            <rect width="64" height="64" rx="14" fill="#356ee0" />
            <text x="32" y="43" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="25" font-weight="bold" fill="white">C++</text>
          </svg>
          <span class="display-font truncate text-[1.05rem] tracking-tight" style="color: var(--text-primary);">EduC++</span>
        </a>
        <p class="mt-1 text-xs font-normal" style="color: var(--text-muted);">Modern C++ documentation studio</p>
        <div class="mt-2 flex flex-wrap gap-1.5">
          <span class="chip">C++20</span>
          <span class="chip">Hands-on</span>
        </div>
      </div>
      <!-- Desktop theme toggle -->
      <button
        id="desktop-theme-toggle"
        class="hover-lift inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border"
        style="border-color: var(--border-soft); color: var(--text-secondary); background: var(--surface-elevated);"
        aria-label="Toggle dark mode"
      >
        <svg class="h-5 w-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg class="hidden h-5 w-5 dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Module list -->
  <nav class="flex-1 px-2.5 py-3.5">
    {modules.map((mod) => (
      <ModuleGroup module={mod} currentSlug={currentSlug} />
    ))}
  </nav>
</div>
