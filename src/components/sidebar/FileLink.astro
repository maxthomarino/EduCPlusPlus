---
import type { SidebarFile } from "../../lib/types.js";

interface Props {
  file: SidebarFile;
  isActive: boolean;
}

const { file, isActive } = Astro.props;
---

<a
  href={`/${file.slug}`}
  class:list={["fl", isActive && "fl--active"]}
  title={file.shortTitle}
>
  <span class="fl-dot" />
  <span class="fl-text">{file.shortTitle}</span>
</a>

<style>
  .fl {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.5rem;
    border-radius: 0.35rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.14s ease, background 0.14s ease;
    text-decoration: none;
  }

  .fl:hover {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-muted) 45%, transparent);
  }

  .fl--active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent-soft) 35%, transparent);
    font-weight: 600;
  }

  .fl--active:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent-soft) 50%, transparent);
  }

  .fl-dot {
    width: 3.5px;
    height: 3.5px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--border-strong);
    opacity: 0.4;
    transition: background 0.14s ease, opacity 0.14s ease, transform 0.14s ease;
  }

  .fl--active .fl-dot {
    background: var(--accent);
    opacity: 1;
    transform: scale(1.4);
  }

  .fl-text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
