---
import type { SidebarFile } from "../../lib/types.js";

interface Props {
  file: SidebarFile;
  isActive: boolean;
}

const { file, isActive } = Astro.props;
---

<a
  href={`/${file.slug}`}
  class:list={[
    "block truncate rounded-md px-2 py-1 text-sm transition-colors",
    isActive
      ? "bg-blue-50 font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-400"
      : "text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-200",
  ]}
  title={file.shortTitle}
>
  {file.shortTitle}
</a>
