---
import type { SidebarFile } from "../../lib/types.js";

interface Props {
  file: SidebarFile;
  isActive: boolean;
}

const { file, isActive } = Astro.props;
---

<a
  href={`/${file.slug}`}
  class:list={[
    "hover-lift block truncate rounded-lg border px-2.5 py-1.5 text-sm transition-all",
    isActive
      ? "font-semibold"
      : "font-medium hover:border-[color:var(--border-soft)] hover:bg-[color:var(--surface-muted)] hover:text-[color:var(--text-primary)]",
  ]}
  style={
    isActive
      ? "border-color: color-mix(in srgb, var(--accent) 30%, var(--border-soft)); background: color-mix(in srgb, var(--accent-soft) 66%, var(--surface-elevated)); color: var(--text-primary);"
      : "border-color: transparent; background: transparent; color: var(--text-secondary);"
  }
  title={file.shortTitle}
>
  {file.shortTitle}
</a>
