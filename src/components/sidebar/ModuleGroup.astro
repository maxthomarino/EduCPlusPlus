---
import FileLink from "./FileLink.astro";
import type { SidebarModule } from "../../lib/types.js";

interface Props {
  module: SidebarModule;
  currentSlug: string;
}

const { module, currentSlug } = Astro.props;

// Auto-open if current page is in this module
const isActive = module.subfolders.some((sub) =>
  sub.files.some((f) => f.slug === currentSlug)
);
---

<details class="mb-1" open={isActive}>
  <summary class="flex cursor-pointer items-center gap-2 rounded-md px-2 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:text-slate-300 dark:hover:bg-slate-800">
    <svg class="chevron h-3.5 w-3.5 shrink-0 text-gray-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="inline-flex h-5 w-5 items-center justify-center rounded bg-blue-100 text-[10px] font-bold text-blue-600 dark:bg-blue-900/50 dark:text-blue-400">
      {String(module.order).padStart(2, "0")}
    </span>
    <span class="truncate">{module.title}</span>
  </summary>

  <div class="ml-4 mt-0.5 border-l border-gray-200 pl-2 dark:border-slate-700">
    {module.subfolders.map((sub) => (
      <div class="mb-1">
        {module.subfolders.length > 1 && (
          <p class="px-2 py-1 text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500">
            {sub.name.replace(/_/g, " ")}
          </p>
        )}
        {sub.files.map((file) => (
          <FileLink file={file} isActive={file.slug === currentSlug} />
        ))}
      </div>
    ))}
  </div>
</details>
