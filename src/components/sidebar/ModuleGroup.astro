---
import FileLink from "./FileLink.astro";
import type { SidebarModule } from "../../lib/types.js";

interface Props {
  module: SidebarModule;
  currentSlug: string;
}

const { module, currentSlug } = Astro.props;

// Auto-open if current page is in this module
const isActive = module.subfolders.some((sub) =>
  sub.files.some((f) => f.slug === currentSlug)
);
const fileCount = module.subfolders.reduce((sum, sub) => sum + sub.files.length, 0);
---

<details class="mb-1" open={isActive}>
  <summary
    class="hover-lift group flex cursor-pointer items-center gap-2 rounded-xl border px-2.5 py-2 text-sm font-semibold"
    style={
      isActive
        ? "border-color: color-mix(in srgb, var(--accent) 34%, var(--border-soft)); background: color-mix(in srgb, var(--accent-soft) 70%, var(--surface-elevated)); color: var(--text-primary);"
        : "border-color: transparent; color: var(--text-secondary); background: transparent;"
    }
  >
    <svg class="chevron h-3.5 w-3.5 shrink-0" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span
      class="inline-flex h-5 min-w-5 items-center justify-center rounded-md px-1 text-[10px] font-bold"
      style={
        isActive
          ? "background: var(--accent); color: var(--text-inverse);"
          : "background: var(--surface-muted); color: var(--text-secondary);"
      }
    >
      {String(module.order).padStart(2, "0")}
    </span>
    <span class="truncate">{module.title}</span>
    <span class="ml-auto text-[10px] font-bold uppercase tracking-[0.08em]" style="color: var(--text-muted);">{fileCount}</span>
  </summary>

  <div class="ml-3 mt-1 border-l pl-2.5" style="border-color: var(--border-soft);">
    {module.subfolders.map((sub) => (
      <div class="mb-1">
        {module.subfolders.length > 1 && (
          <p class="px-2 py-1 text-[10px] font-bold uppercase tracking-[0.13em]" style="color: var(--text-muted);">
            {sub.name.replace(/_/g, " ")}
          </p>
        )}
        {sub.files.map((file) => (
          <FileLink file={file} isActive={file.slug === currentSlug} />
        ))}
      </div>
    ))}
  </div>
</details>
