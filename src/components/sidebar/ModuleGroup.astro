---
import FileLink from "./FileLink.astro";
import type { SidebarModule } from "../../lib/types.js";

interface Props {
  module: SidebarModule;
  currentSlug: string;
}

const { module, currentSlug } = Astro.props;

// Auto-open if current page is in this module
const isActive = module.subfolders.some((sub) =>
  sub.files.some((f) => f.slug === currentSlug)
);
const fileCount = module.subfolders.reduce((sum, sub) => sum + sub.files.length, 0);
---

<details class="mg" open={isActive}>
  <summary
    class:list={["mg-summary", isActive && "mg-summary--active"]}
  >
    <svg class="chevron mg-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
    </svg>
    <span class:list={["mg-num", isActive && "mg-num--active"]}>
      {String(module.order).padStart(2, "0")}
    </span>
    <span class="mg-title">{module.title}</span>
    <span class="mg-count">{fileCount}</span>
  </summary>

  <div class="mg-children">
    {module.subfolders.map((sub) => (
      <div class="mg-sub">
        {module.subfolders.length > 1 && (
          <p class="mg-sub-label">
            {sub.name.replace(/_/g, " ")}
          </p>
        )}
        {sub.files.map((file) => (
          <FileLink file={file} isActive={file.slug === currentSlug} />
        ))}
      </div>
    ))}
  </div>
</details>

<style>
  .mg {
    margin-bottom: 0.15rem;
  }

  .mg-summary {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.38rem 0.55rem;
    border-radius: 0.45rem;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    color: var(--text-secondary);
    border: 1px solid transparent;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .mg-summary::-webkit-details-marker { display: none; }
  .mg-summary::marker { display: none; content: ""; }

  .mg-summary:hover {
    background: color-mix(in srgb, var(--surface-muted) 60%, transparent);
    color: var(--text-primary);
  }

  .mg-summary--active {
    background: color-mix(in srgb, var(--accent-soft) 45%, var(--surface-elevated));
    border-color: color-mix(in srgb, var(--accent) 18%, var(--border-soft));
    color: var(--text-primary);
  }

  .mg-chevron {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .mg-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 0.2rem;
    border-radius: 0.25rem;
    font-family: var(--font-code);
    font-size: 0.6rem;
    font-weight: 700;
    flex-shrink: 0;
    background: var(--surface-muted);
    color: var(--text-muted);
  }

  .mg-num--active {
    background: var(--accent);
    color: #fff;
  }

  .mg-title {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .mg-count {
    font-family: var(--font-code);
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--text-muted);
    flex-shrink: 0;
    opacity: 0.7;
  }

  .mg-children {
    margin-left: 0.9rem;
    margin-top: 0.2rem;
    padding-left: 0.7rem;
    border-left: 1.5px solid var(--border-soft);
  }

  .mg-sub {
    margin-bottom: 0.15rem;
  }

  .mg-sub-label {
    padding: 0.2rem 0.5rem;
    font-size: 0.62rem;
    font-weight: 650;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    opacity: 0.7;
  }
</style>
