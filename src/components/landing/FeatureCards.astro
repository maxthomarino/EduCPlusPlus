---
/**
 * FeatureCards — "Why EduC++" benefits section with 6 icon cards.
 * Static content, no props needed.
 */

const cards = [
  {
    title: "Structured C++20 Curriculum",
    description: "Progressive module-based learning that guides you from fundamentals to advanced features in a logical sequence.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M8 7h6"/><path d="M8 11h4"/></svg>`,
  },
  {
    title: "Runnable Code Examples",
    description: "Every concept paired with working code you can study, modify, and run to solidify your understanding.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
  },
  {
    title: "Decision-Making Guidance",
    description: "When-to-use-what frameworks that help you choose the right tool, pattern, or feature for each situation.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
  },
  {
    title: "Interactive Quiz",
    description: "128 multiple-choice questions across 15 topics to test and reinforce your C++ knowledge.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  },
  {
    title: "Editorial Articles",
    description: "Deep dives and practical discussions that go beyond the lesson path into real-world C++ topics.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    title: "Clear Explanations",
    description: "FAQs, common pitfalls, and key takeaways with every lesson so nothing is left unclear.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h8"/><path d="M8 14h4"/></svg>`,
  },
];
---

<section class="page-reveal mb-8">
  <div class="mb-4">
    <p class="eyebrow gradient-title mb-1">Platform Highlights</p>
    <h2 class="display-font text-2xl font-semibold tracking-tight" style="color: var(--text-primary);">
      Why <span class="gradient-title">EduC++</span>?
    </h2>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {cards.map((card, i) => (
      <div
        class="surface-card hover-lift page-reveal p-5"
        style={`animation-delay: ${i * 80}ms;`}
      >
        <div
          class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg"
          style="background: var(--accent-soft); color: var(--accent);"
          set:html={card.icon}
        />
        <h3
          class="display-font text-base font-semibold tracking-tight"
          style="color: var(--text-primary);"
        >
          {card.title}
        </h3>
        <p class="mt-1.5 text-sm leading-relaxed" style="color: var(--text-secondary);">
          {card.description}
        </p>
      </div>
    ))}
  </div>
</section>
