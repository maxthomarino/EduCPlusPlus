---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  linkText: string;
  linkHref: string;
  variant?: "default" | "accent" | "deep";
}

const { eyebrow, title, description, linkText, linkHref, variant = "default" } = Astro.props;

const variantStyles = {
  default: {
    border: "var(--accent)",
    accent: "var(--accent)",
    accentSoft: "var(--accent-soft)",
  },
  accent: {
    border: "var(--success)",
    accent: "var(--success)",
    accentSoft: "var(--success-soft)",
  },
  deep: {
    border: "var(--deep)",
    accent: "var(--deep)",
    accentSoft: "var(--deep-soft)",
  },
};

const v = variantStyles[variant];
---

<div
  class="cta-card surface-card page-reveal relative overflow-hidden p-6 sm:p-8"
  style={`border-top: 3px solid ${v.border};`}
>
  <div class="relative z-10">
    <p class="eyebrow mb-2" style={`color: ${v.accent};`}>{eyebrow}</p>
    <h2 class="display-font text-xl font-semibold tracking-tight sm:text-2xl">
      <span class="gradient-title">{title}</span>
    </h2>
    <p class="mt-2 max-w-2xl text-sm sm:text-base" style="color: var(--text-secondary);">
      {description}
    </p>
    <a
      href={linkHref}
      class="hover-lift mt-5 inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold transition-all"
      style={`background: ${v.accentSoft}; color: ${v.accent}; border: 1px solid color-mix(in srgb, ${v.accent} 20%, transparent);`}
    >
      {linkText}
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
  <div
    class="pointer-events-none absolute -right-8 -bottom-8 h-32 w-32 rounded-full opacity-[0.07]"
    style={`background: radial-gradient(circle, ${v.accent}, transparent 70%);`}
  />
</div>
