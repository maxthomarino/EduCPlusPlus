---
import type { SidebarModule } from "../../lib/types.js";

interface Props {
  sidebarData: SidebarModule[];
}

const { sidebarData } = Astro.props;

interface Tier {
  label: string;
  color: string;
  colorSoft: string;
  modules: SidebarModule[];
  lessonCount: number;
  firstSlug: string;
}

function buildTiers(modules: SidebarModule[]): Tier[] {
  const tiers: Tier[] = [
    { label: "Beginner", color: "var(--success)", colorSoft: "var(--success-soft)", modules: [], lessonCount: 0, firstSlug: "" },
    { label: "Intermediate", color: "var(--warning)", colorSoft: "var(--warning-soft)", modules: [], lessonCount: 0, firstSlug: "" },
    { label: "Advanced", color: "var(--deep)", colorSoft: "var(--deep-soft)", modules: [], lessonCount: 0, firstSlug: "" },
  ];

  for (const mod of modules) {
    const tier = mod.order <= 4 ? tiers[0] : mod.order <= 9 ? tiers[1] : tiers[2];
    tier.modules.push(mod);
    tier.lessonCount += mod.subfolders.reduce((sum, sub) => sum + sub.files.length, 0);
    if (!tier.firstSlug) {
      const first = mod.subfolders[0]?.files[0];
      if (first) tier.firstSlug = `/${first.slug}`;
    }
  }

  return tiers.filter((t) => t.modules.length > 0);
}

const tiers = buildTiers(sidebarData);
---

<section class="surface-card-soft page-reveal mb-8 p-5 sm:p-6">
  <p class="eyebrow mb-1">Your Journey</p>
  <h2 class="display-font text-xl font-semibold tracking-tight mb-5" style="color: var(--text-primary);">
    Learning <span class="gradient-title">Path</span>
  </h2>

  <div class="learning-path-track">
    {tiers.map((tier, i) => (
      <div class="learning-path-tier">
        {i > 0 && <div class="learning-path-connector" style={`background: linear-gradient(to right, ${tiers[i - 1].color}, ${tier.color});`} />}
        <a href={tier.firstSlug || "#"} class="learning-path-card hover-lift" style={`border: 1px solid color-mix(in srgb, ${tier.color} 24%, var(--border-soft)); background: color-mix(in srgb, ${tier.colorSoft} 55%, var(--surface-elevated));`}>
          <div class="flex items-center gap-2 mb-2">
            <span
              class="inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-semibold tracking-[0.04em]"
              style={`color: ${tier.color}; background: color-mix(in srgb, ${tier.colorSoft} 80%, transparent);`}
            >
              {tier.label}
            </span>
            <span class="text-[11px] font-medium" style="color: var(--text-muted);">
              {tier.lessonCount} lessons
            </span>
          </div>
          <div class="flex items-center gap-2 mb-2">
            <span class="learning-path-dot" style={`background: ${tier.color};`} />
            <span class="text-xs font-semibold" style={`color: ${tier.color};`}>
              Modules {tier.modules[0].order}–{tier.modules[tier.modules.length - 1].order}
            </span>
          </div>
          <ul class="learning-path-list">
            {tier.modules.map((mod) => (
              <li class="text-xs truncate" style="color: var(--text-secondary);">
                {mod.title}
              </li>
            ))}
          </ul>
        </a>
      </div>
    ))}
  </div>
</section>

<style>
  .learning-path-track {
    display: flex;
    gap: 0;
    align-items: stretch;
  }

  .learning-path-tier {
    flex: 1;
    display: flex;
    align-items: stretch;
    position: relative;
  }

  .learning-path-connector {
    position: absolute;
    left: -1rem;
    top: 50%;
    width: 2rem;
    height: 2px;
    z-index: 1;
  }

  .learning-path-card {
    display: block;
    padding: 1rem;
    border-radius: 0.75rem;
    width: 100%;
    text-decoration: none;
    margin-left: 1rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .learning-path-tier:first-child .learning-path-card {
    margin-left: 0;
  }

  .learning-path-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .learning-path-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  @media (max-width: 640px) {
    .learning-path-track {
      flex-direction: column;
      gap: 0;
    }

    .learning-path-connector {
      left: 50%;
      top: -0.75rem;
      width: 2px;
      height: 1.5rem;
      transform: translateX(-50%);
      background: revert;
    }

    .learning-path-card {
      margin-left: 0;
      margin-top: 1rem;
    }

    .learning-path-tier:first-child .learning-path-card {
      margin-top: 0;
    }
  }
</style>
