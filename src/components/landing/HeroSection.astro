---
import CodeDecoration from "./CodeDecoration.astro";

interface Props {
  totalLessons: number;
  totalModules: number;
  totalArticles: number;
  firstLessonSlug: string;
}

const { totalLessons, totalModules, totalArticles, firstLessonSlug } = Astro.props;
---

<section class="surface-card page-reveal relative mb-8 overflow-hidden p-6 sm:p-8">
  <CodeDecoration class="right-4 top-4 hidden lg:block" />

  <p class="eyebrow gradient-title mb-3">Modern C++ Learning Studio</p>

  <h1 class="display-font text-4xl font-semibold tracking-tight sm:text-5xl">
    <span style="color: var(--text-primary);">Master Modern </span>
    <span class="gradient-title">C++20</span>
  </h1>

  <p class="mt-4 max-w-2xl text-base sm:text-lg" style="color: var(--text-secondary);">
    A structured path from core fundamentals to advanced features, with focused explanations,
    runnable code, and clear decision-making guidance.
  </p>

  <div class="mt-6 flex flex-wrap gap-3">
    <a
      href={`/${firstLessonSlug}`}
      class="hero-cta-primary hover-lift inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold"
    >
      Start Learning
    </a>
    <a
      href="/quiz"
      class="hero-cta-secondary hover-lift inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold"
    >
      Take the Quiz
    </a>
  </div>

  <div class="mt-5 flex flex-wrap gap-2.5">
    <span class="metric-pill"><strong>{totalLessons}</strong>&nbsp;lessons</span>
    <span class="metric-pill"><strong>{totalModules}</strong>&nbsp;modules</span>
    <span class="metric-pill"><strong>{totalArticles}</strong>&nbsp;articles</span>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    <span class="chip">C++20-first</span>
    <span class="chip">Guided progression</span>
    <span class="chip">Concept clarity</span>
    <span class="chip">Runnable examples</span>
  </div>
</section>

<style>
  .hero-cta-primary {
    background: var(--accent);
    color: var(--surface-base);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .hero-cta-primary:hover {
    opacity: 0.9;
  }

  .hero-cta-secondary {
    border: 1px solid var(--border-soft);
    background: var(--surface-elevated);
    color: var(--text-primary);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .hero-cta-secondary:hover {
    border-color: var(--accent);
  }
</style>
